# Snort / Suricata Rules — Phishing Network: a-gratis.uk
# ========================================================
# Author    : rwx4m
# Date      : 2026-05-16
# Version   : 1.0
# TLP       : WHITE
# Reference : https://sudo-rwx4m.my.id/projects/TI-Report_Phishing-Network_a-gratis-uk
#
# All domains verified HTTP 200 on 2026-05-16.
# IP addresses are Cloudflare anycast proxies — do NOT use for firewall block.
# Use domain-based rules (HTTP Host header) for accurate detection.
# ========================================================

# ── Rule 1: Any subdomain of a-gratis.uk ──────────────────────────────────────
alert http $HOME_NET any -> $EXTERNAL_NET any (
    msg:"PHISHING a-gratis.uk Network — Government Impersonation ID/MY";
    flow:established,to_server;
    http.host;
    content:"a-gratis.uk";
    endswith;
    classtype:social-engineering;
    sid:9000001;
    rev:1;
    metadata:
        affected_products Web_Browser,
        attack_target Client_Endpoint,
        created_at 2026_05_16,
        confidence HIGH,
        tlp WHITE,
        author rwx4m;
)

